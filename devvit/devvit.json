{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "hexlifeapp",
  "post": {
    "entrypoints": {
      "default": {
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {},
  "menu": {
    "items": [
      {
        "label": "[hexlifeapp] New Post",
        "description": "Create a new hexlifeapp post.",
        "location": "subreddit",
        "endpoint": "/internal/on/menu/new-post"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on/app/install"
  },
  "scripts": {
    "dev": "npm run watch"
  }
}
