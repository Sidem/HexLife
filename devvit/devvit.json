{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "hexlifeapp",
  "post": {
    "entrypoints": {
      "default": {
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {},
  "menu": {
    "items": [
      {
        "label": "New HexLife post",
        "description": "Create a post from a world code exported in HexLife Explorer.",
        "location": "subreddit",
        "endpoint": "/internal/on/menu/new-post"
      }
    ]
  },
  "forms": {
    "newWorldPost": "/internal/on/form/new-post"
  },
  "triggers": {
    "onAppInstall": "/internal/on/app/install",
    "onPostSubmit": "/internal/on/post/submit"
  },
  "scripts": {
    "dev": "npm run watch"
  },
  "dev": {
    "subreddit": "hexlifeapp_dev"
  }
}
